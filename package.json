{
  "name": "shreni",
  "version": "0.1.0",
  "description": "Local-first, bring-your-own-model agent harness that turns a backlog into reviewed, merged code",
  "main": "dist/index.js",
  "bin": {
    "shreni": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "certify": "tsx scripts/certify-pack.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:binary": "node scripts/build-binary.mjs",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "packs",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE",
    "TRADEMARK.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TeakWood/Shreni.git"
  },
  "keywords": [
    "ai-agents",
    "autonomous-agents",
    "coding-agent",
    "code-review",
    "orchestrator",
    "agent-harness",
    "local-first",
    "bring-your-own-model"
  ],
  "author": "TeakWood <teakwood.dev@gmail.com>",
  "license": "Apache-2.0",
  "type": "commonjs",
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "bugs": {
    "url": "https://github.com/TeakWood/Shreni/issues"
  },
  "homepage": "https://github.com/TeakWood/Shreni#readme",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "postject": "1.0.0-alpha.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@types/js-yaml": "^4.0.9",
    "fastify": "^5.8.5",
    "js-yaml": "^4.2.0",
    "zod": "^4.4.3"
  }
}
